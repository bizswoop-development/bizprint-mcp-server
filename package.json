{
  "name": "@bizswoop/bizprint-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for the BizPrint Cloud Print API",
  "type": "module",
  "bin": {
    "bizprint-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node build/shebang.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "pack:mcpb": "npm run build && node build/pack-mcpb.cjs",
    "pack:mcpb:validate": "mcpb info bizprint-mcp-server.mcpb"
  },
  "keywords": [
    "mcp",
    "bizprint",
    "printing",
    "cloud-print",
    "model-context-protocol"
  ],
  "author": "BizSwoop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BizSwoop/bizprint-mcp-server.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
